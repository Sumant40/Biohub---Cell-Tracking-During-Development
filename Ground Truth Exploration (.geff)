    "graph_stats = []\n",
    "\n",
    "for file in geff_files:\n",
    "\n",
    "    gt = zarr.open(file)\n",
    "\n",
    "    edges = np.array(gt[\"edges\"][\"ids\"])\n",
    "\n",
    "    G = nx.DiGraph()\n",
    "\n",
    "    G.add_edges_from(edges)\n",
    "\n",
    "    branching = sum(\n",
    "\n",
    "        G.out_degree(n) > 1\n",
    "\n",
    "        for n in G.nodes()\n",
    "\n",
    "    )\n",
    "\n",
    "    graph_stats.append({\n",
    "\n",
    "        \"sample\": file.stem,\n",
    "\n",
    "        \"nodes\": G.number_of_nodes(),\n",
    "\n",
    "        \"edges\": G.number_of_edges(),\n",
    "\n",
    "        \"components\": nx.number_weakly_connected_components(G),\n",
    "\n",
    "        \"branch_points\": branching\n",
    "\n",
    "    })\n",
    "\n",
    "graph_stats = pd.DataFrame(graph_stats)\n",
    "\n",
    "graph_stats.head()"
   ]
  },
