   "source": [
    "summary = []\n",
    "\n",
    "for file in geff_files:\n",
    "\n",
    "    gt = zarr.open(file, mode=\"r\")\n",
    "\n",
    "    nodes = np.array(gt[\"nodes\"][\"ids\"])\n",
    "    edges = np.array(gt[\"edges\"][\"ids\"])\n",
    "\n",
    "    t = np.array(gt[\"nodes\"][\"props\"][\"t\"][\"values\"])\n",
    "\n",
    "    embryo = file.stem.split(\"_\")[0]\n",
    "\n",
    "    summary.append({\n",
    "\n",
    "        \"sample\": file.stem,\n",
    "\n",
    "        \"embryo\": embryo,\n",
    "\n",
    "        \"nodes\": len(nodes),\n",
    "\n",
    "        \"edges\": len(edges),\n",
    "\n",
    "        \"frames_annotated\": len(np.unique(t)),\n",
    "\n",
    "        \"first_frame\": t.min(),\n",
    "\n",
    "        \"last_frame\": t.max(),\n",
    "\n",
    "        \"track_duration\": t.max() - t.min() + 1\n",
    "\n",
    "    })\n",
    "\n",
    "summary = pd.DataFrame(summary)\n",
    "\n",
    "summary.head()"
   ]
